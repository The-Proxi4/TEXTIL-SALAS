@model textil_salas.Models.B2BQuoteViewModel
@{
    ViewData["Title"] = "Empresas";
}

<section class="hero hero-dark compact">
    <div class="container narrow text-center">
        <p class="eyebrow">Programa empresarial</p>
        <h1>Compras corporativas</h1>
        <p>Textiles premium para hoteles, spas, gimnasios y empresas con precios por volumen.</p>
    </div>
</section>

<section class="section">
    <div class="container benefits-grid">
        <article class="info-card"><h3>Precios mayoreo</h3><p>Descuentos desde 50 unidades.</p></article>
        <article class="info-card"><h3>Personalización</h3><p>Bordado de logo y colores.</p></article>
        <article class="info-card"><h3>Envío directo</h3><p>Entregas programadas.</p></article>
        <article class="info-card"><h3>Cuenta dedicada</h3><p>Atención en 24 horas.</p></article>
    </div>
</section>

<section class="section section-muted">
    <div class="container grid-2 align-start">

        <!-- FORMULARIO -->
        <div class="panel form-panel">
            <div class="section-heading left">
                <p class="eyebrow">Cotización</p>
                <h2>Solicita una cotización</h2>
            </div>

            @if (TempData["Success"] is string success)
            {
                <div class="alert-success">@success</div>
            }

            <form method="post" class="form-stack spaced">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Company"></label>
                    <input asp-for="Company" class="input" />
                    <span asp-validation-for="Company" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Ruc"></label>
                    <input asp-for="Ruc" maxlength="11" class="input" />
                    <span asp-validation-for="Ruc" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ContactName"></label>
                    <input asp-for="ContactName" class="input" />
                    <span asp-validation-for="ContactName" class="field-error"></span>
                </div>

                <div class="grid-2 gap">
                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="input" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone"></label>
                        <input asp-for="Phone" class="input" />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Message"></label>
                    <textarea asp-for="Message" rows="4" class="input"></textarea>
                    <span asp-validation-for="Message" class="field-error"></span>
                </div>

                <button class="btn btn-primary full-width" type="submit">
                    Enviar solicitud
                </button>
            </form>
        </div>

        <!-- PANEL DERECHO -->
        <aside class="panel quote-panel">
            <div class="section-heading left">
                <p class="eyebrow">Detalle demo</p>
                <h2>Cotización referencial</h2>
            </div>

            <div id="quote-detail" class="quote-box"></div>

            <div class="quote-total">
                <span>Total estimado</span>
                <strong id="quote-total">S/ 0.00</strong>
            </div>

            <p class="help-note">
                Puedes modificar esto en clase fácilmente (JS simple).
            </p>
        </aside>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/b2b.js" asp-append-version="true"></script>
}