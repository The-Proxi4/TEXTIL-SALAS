@model List<Product>
@{
    ViewData["Title"] = "Tienda";
    var category = (string?)ViewBag.Category ?? "all";
    var query = (string?)ViewBag.Query ?? string.Empty;
}

<section class="page-header container narrow">
    <p class="eyebrow">Catálogo</p>
    <h1>Nuestra Tienda</h1>
    <p>100% algodón prima · 700–750 GSM · precios en soles.</p>
</section>

<div class="shop-top-actions container">
    <div>
        <p class="eyebrow">Carrito rápido</p>
        <h2>Tu carrito siempre disponible</h2>
        <p>Accede a tu carrito desde aquí y sigue comprando sin perder tu selección.</p>
    </div>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-primary shop-cart-button">🛒 Ver carrito</a>
</div>

<section class="container section-tight">
<form method="get" class="filters-bar">
    <input type="text" name="q" value="@query" placeholder="Buscar productos..." />

    <select name="category">
        <option value="all">Todo</option>

        @foreach (var cat in ViewBag.CategoriasActivas)
        {
            <option value="@cat.Nombre" selected="@(category == cat.Nombre)">
                @cat.Nombre
            </option>
        }
    </select>

    <button type="submit" class="btn btn-primary">Filtrar</button>
</form>

    <div class="product-grid">
        @foreach (var item in Model)
        {
            <article class="product-card">
                <img src="@item.ImageUrl" alt="@item.Name" />
                <div class="product-body">
                    <span class="badge">@item.Subcategory</span>
                    <h3>@item.Name</h3>
                    <p>@item.Description</p>
                    <div class="product-meta">
                        <strong>S/@item.Price.ToString("0.00")</strong>
                        <span>@string.Join(" · ", item.Sizes)</span>
                    </div>
                </div>
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="product-cart-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@item.Id" />
                    <div class="product-cart-controls">
                        <div class="quantity-field">
                            <label>Cantidad</label>
                            <input type="number" name="quantity" min="1" value="1" />
                        </div>
                        <button type="submit" class="btn btn-primary">Añadir</button>
                    </div>
                </form>
            </article>
        }
    </div>

    <div class="shop-bottom-actions container">
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline">Ir al carrito</a>
        <p class="subtle-note">También puedes usar el botón superior para abrir tu carrito en cualquier momento.</p>
    </div>
</section>
