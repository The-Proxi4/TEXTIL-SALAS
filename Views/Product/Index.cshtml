@model List<textil_salas.Models.Product>

@{
    ViewData["Title"] = "Gestión de Productos";
}

<section class="page-header container">
    <p class="eyebrow">Backoffice</p>
    <h1>Gestión de Catálogo</h1>
    <p>Administra los productos del ecommerce.</p>
</section>

<section class="container section-tight">

    @* Mensaje de éxito *@
    @if (TempData["Exito"] != null)
    {
        <div class="alert-success">✓ @TempData["Exito"]</div>
    }

    <div class="panel">
        <div class="section-heading left" style="display:flex; justify-content:space-between; align-items:center; padding: 20px 20px 0;">
            <h2 style="margin:0;">Productos</h2>
            <a asp-controller="Product" asp-action="Create" class="btn btn-primary">+ Nuevo producto</a>
        </div>

        @* Filtros *@
        <form method="get" class="filters-bar" style="padding: 20px; border-bottom: 1px solid var(--border);">
            <input type="text" name="q" placeholder="Buscar por nombre..." value="@ViewBag.Query" />
            <select name="category">
                <option value="all">Todas las categorías</option>
                @foreach (var cat in ViewBag.CategoriasActivas)
                {
                    <option value="@cat.Nombre" selected="@(ViewBag.Category == cat.Nombre ? "selected" : null)">@cat.Nombre</option>
                }
            </select>
            <select name="status">
                <option value="all" selected="@(ViewBag.Status == "all" ? "selected" : null)">Todos los estados</option>
                <option value="active" selected="@(ViewBag.Status == "active" ? "selected" : null)">Activos</option>
                <option value="inactive" selected="@(ViewBag.Status == "inactive" ? "selected" : null)">Inactivos</option>
            </select>
            <button class="btn btn-primary">Filtrar</button>
        </form>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prod in Model)
                    {
                        <tr>
                            <td>#@prod.Id</td>
                            <td>@prod.Name</td>
                            <td>@prod.Category</td>
                            <td>S/@prod.Price.ToString("0.00")</td>
                            <td>
                                <span class="status-chip" style="@(prod.IsActive ? "background:#e7f7ed; color:#116530;" : "background:#fee2e2; color:#991b1b;")">
                                    @(prod.IsActive ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td style="display:flex; gap:8px; flex-wrap:wrap;">
                                @* Editar *@
                                <a asp-controller="Product" asp-action="Edit" asp-route-id="@prod.Id"
                                   class="btn btn-outline" style="padding:8px 14px; font-size:0.85rem;">
                                    Editar
                                </a>

                                @* Soft delete / reactivar *@
                                @if (prod.IsActive)
                                {
                                    <form asp-controller="Product" asp-action="Delete" asp-route-id="@prod.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn"
                                                style="background:#fee2e2; color:#991b1b; border-color:#fca5a5; padding:8px 14px; font-size:0.85rem;"
                                                onclick="return confirm('¿Desactivar este producto?')">
                                            Desactivar
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Product" asp-action="Activate" asp-route-id="@prod.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn"
                                                style="background:#e7f7ed; color:#116530; border-color:#b4e2c2; padding:8px 14px; font-size:0.85rem;">
                                            Reactivar
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>