@model textil_salas.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<section class="page-header container narrow">
    <p class="eyebrow">Checkout</p>
    <h1>Finalizar compra</h1>
    <p>Revisa tu pedido y completa tus datos de envío y pago.</p>
</section>

<section class="container section-tight">
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">✗ @TempData["Error"]</div>
    }

    <div class="panel grid grid-2">
        <div>
            <h2>Resumen del pedido</h2>
            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>S/@(item.UnitPrice * item.Quantity).ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="cart-summary">
                <p>Total:</p>
                <strong>S/@Model.Total.ToString("0.00")</strong>
            </div>
        </div>

        <div>
            <h2>Datos de envío y pago</h2>
            <form asp-action="PlaceOrder" method="post" class="form-stack">
                @Html.AntiForgeryToken()

                <div>
                    <label asp-for="ShippingAddress">Dirección</label>
                    <input asp-for="ShippingAddress" placeholder="Av. Ejemplo 123" />
                    <span asp-validation-for="ShippingAddress" class="field-error"></span>
                </div>

                <div>
                    <label asp-for="District">Distrito</label>
                    <input asp-for="District" placeholder="Miraflores" />
                    <span asp-validation-for="District" class="field-error"></span>
                </div>

                <div>
                    <label asp-for="Phone">Teléfono</label>
                    <input asp-for="Phone" placeholder="999 999 999" />
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>

                <div>
                    <label asp-for="Reference">Referencia</label>
                    <input asp-for="Reference" placeholder="Piso 2, puerta azul" />
                    <span asp-validation-for="Reference" class="field-error"></span>
                </div>

                <div>
                    <label>Método de pago</label>
                    <div class="payment-options">
                        <label>
                            <input type="radio" name="PaymentMethod" value="Yape/Plin" @(Model.PaymentMethod == "Yape/Plin" ? "checked" : "") /> Yape / Plin
                        </label>
                        <label>
                            <input type="radio" name="PaymentMethod" value="Tarjeta" @(Model.PaymentMethod == "Tarjeta" ? "checked" : "") /> Tarjeta débito / crédito
                        </label>
                        <label>
                            <input type="radio" name="PaymentMethod" value="Efectivo" @(Model.PaymentMethod == "Efectivo" ? "checked" : "") /> Pago en efectivo
                        </label>
                    </div>
                    <span asp-validation-for="PaymentMethod" class="field-error"></span>
                </div>

                <button type="submit" class="btn btn-primary">Confirmar compra</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
