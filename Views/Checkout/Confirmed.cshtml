@{
    ViewData["Title"] = "Compra confirmada";
}

<section class="page-header container narrow">
    <p class="eyebrow">Compra confirmada</p>
    <h1>¡Gracias por tu compra!</h1>
    <p>Tu pedido se ha generado correctamente.</p>
</section>

<section class="container section-tight">
    <div class="panel confirm-panel">
        <div class="confirm-badge">✓</div>
        <p class="eyebrow">Compra confirmada</p>
        <h2>¡Gracias por tu compra!</h2>
        <p>Tu pedido se ha generado correctamente y estamos preparando el envío.</p>
        <div class="order-number">Orden #@ViewData["OrderNumber"]</div>
        <p class="confirm-footnote">Recibirás una notificación pronto con los detalles de seguimiento.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
    </div>
</section>
