@{
    ViewData["Title"] = "Compra confirmada";
}

<section class="page-header container narrow">
    <p class="eyebrow">Compra confirmada</p>
    <h1>¡Gracias por tu compra!</h1>
    <p>Tu pedido se ha generado correctamente.</p>
</section>

<section class="container section-tight">
    <div class="panel">
        <p>Tu número de orden es:</p>
        <h2>@ViewData["OrderNumber"]</h2>
        <p>En breve recibirás más información sobre el seguimiento.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
    </div>
</section>
