@{
    ViewData["Title"] = "Recuperar contraseña";
}

<section class="hero hero-dark compact">
    <div class="container narrow text-center">
        <p class="eyebrow">Seguridad</p>
        <h1>Recupera tu acceso</h1>
        <p>Te ayudamos a volver a ingresar a tu cuenta de forma segura.</p>
    </div>
</section>

<section class="section">
    <div class="container narrow">

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">
                ⚠ @ViewBag.Error
            </div>
        }

        @if (TempData["Reset"] != null)
        {
            <div class="alert-success">
                ✔ @TempData["Reset"]
            </div>
        }

        <div class="panel">

            <form method="post" class="form-stack">

                <label>Correo electrónico</label>
                <input name="email"
                       type="email"
                       placeholder="ejemplo@correo.com"
                       required />

                <small class="help-note">
                    Te enviaremos un enlace de recuperación si la cuenta existe.
                </small>

                <button type="submit" class="btn btn-primary">
                    Enviar enlace
                </button>

            </form>

        </div>

        <div class="text-center" style="margin-top:16px;">
            <a asp-controller="Account" asp-action="Login">
                Volver al login
            </a>
        </div>

    </div>
</section>