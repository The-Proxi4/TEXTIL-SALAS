@model textil_salas.Models.RegisterViewModel

@{
    ViewData["Title"] = "Crear cuenta";
}

<section class="hero hero-dark compact">
    <div class="container narrow text-center">
        <p class="eyebrow">Registro</p>
        <h1>Crear una cuenta</h1>
        <p>Ingresa tus datos para empezar a comprar en Textil Salas.</p>
    </div>
</section>

<section class="section">
    <div class="container narrow">

        <div class="panel">
            <form asp-action="Register" method="post" class="form-stack">
                @Html.AntiForgeryToken()

                @* CA-1: Nombre completo *@
                <div>
                    <label asp-for="NombreCompleto">Nombre completo</label>
                    <input asp-for="NombreCompleto" type="text" placeholder="Juan Pérez" />
                    <span asp-validation-for="NombreCompleto" class="field-error"></span>
                </div>

                @* CA-1: Email obligatorio + formato *@
                <div>
                    <label asp-for="Email">Correo electrónico</label>
                    <input asp-for="Email" type="email" placeholder="correo@ejemplo.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                @* CA-1: Contraseña oculta *@
                <div>
                    <label asp-for="Password">Contraseña</label>
                    <input asp-for="Password" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                @* Confirmar contraseña *@
                <div>
                    <label asp-for="ConfirmPassword">Confirmar contraseña</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>

                @* CA-1: Botón registrarse *@
                <button type="submit" class="btn btn-primary">Registrarse</button>

                @* CA-3: Redirigir a login *@
                <p class="help-note text-center">
                    ¿Ya tienes cuenta?
                    <a asp-controller="Account" asp-action="Login"
                       style="color: var(--accent); font-weight:600;">
                        Inicia sesión
                    </a>
                </p>

            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}